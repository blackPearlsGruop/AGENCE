<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onBoardingFragment">
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.ksa.agence.ui.fragment.auth.LoginFragment"
        android:label="LoginFragment"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_confirmOtpFragment"
            app:destination="@id/confirmOtpFragment" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.ksa.agence.ui.fragment.auth.RegisterFragment"
        android:label="RegisterFragment"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_registerFragment_to_confirmOtpFragment"
            app:destination="@id/confirmOtpFragment" />
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/confirmOtpFragment"
        android:name="com.ksa.agence.ui.fragment.auth.ConfirmOtpFragment"
        android:label="ConfirmOtpFragment"
        tools:layout="@layout/fragment_confirm_otp">
        <argument
            android:name="phone"
            app:argType="string" />
        <argument
            android:name="countryCode"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/onBoardingFragment"
        android:name="com.ksa.agence.ui.fragment.splash.OnBoardingFragment"
        android:label="OnBoardingFragment"
        tools:layout="@layout/fragment_on_boading">
        <action
            android:id="@+id/action_onBoardingFragment_to_choosePageFragment2"
            app:destination="@id/choosePageFragment2" />
        <action
            android:id="@+id/action_onBoardingFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/choosePageFragment2"
        android:name="com.ksa.agence.ui.fragment.splash.ChoosePageFragment"
        android:label="ChoosePageFragment"
        tools:layout="@layout/fragment_choose_page">
        <action
            android:id="@+id/action_choosePageFragment2_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>


</navigation>