<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_50sdp"
            android:src="@drawable/logo_splash"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tv_nameUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/somar_bold"
            android:gravity="center"
            android:layout_marginEnd="@dimen/_24sdp"
            android:layout_marginStart="@dimen/_24sdp"
            android:text="@string/we_are_here_to_provide_a_media_experience_customized_for_you"
            android:textColor="@color/text"
            android:layout_marginTop="@dimen/_16sdp"
            android:textSize="@dimen/_20ssp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView2" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_customer"
            style="@style/bottom"
            android:layout_width="0dp"
            android:text="@string/customer"
            android:layout_marginTop="@dimen/_24sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_nameUser" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_provider"
            style="@style/bottom"
            android:layout_width="0dp"
            android:text="@string/provider"
            android:layout_marginTop="@dimen/_16sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_customer" />


        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            app:layout_constraintEnd_toEndOf="@+id/btn_provider"
            app:layout_constraintStart_toStartOf="@+id/btn_provider"
            app:layout_constraintTop_toBottomOf="@+id/btn_provider">


            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:background="@drawable/icon_line_1"
                android:gravity="center" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:fontFamily="@font/somar_bold"
                android:gravity="center"
                android:text="@string/or"
                android:textColor="@color/text"
                android:textSize="@dimen/_16ssp" />


            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:background="@drawable/icon_line_2"
                android:gravity="center" />


        </LinearLayout>


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_guest"
            style="@style/bottom"
            android:layout_width="0dp"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="@string/follow_as_a_guest"
            android:textColor="@color/secondary"
            android:background="@drawable/shape_bottom2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout" />





    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>