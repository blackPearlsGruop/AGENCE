<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <LinearLayout
            android:id="@+id/linear_layout_ar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_16sdp"
            android:background="@drawable/shape_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="@dimen/_8sdp"
                android:text="العربية"
                android:gravity="center"
                android:textColor="@color/grey_bold"
                android:fontFamily="@font/somar_bold"
                android:textSize="@dimen/_22ssp"
                android:drawablePadding="@dimen/_8sdp"
                app:drawableStartCompat="@drawable/icon_saudi_arabia" />


        </LinearLayout>


        <LinearLayout
            android:id="@+id/linear_layout_en"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_16sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linear_layout_ar">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:drawablePadding="@dimen/_8sdp"
                android:fontFamily="@font/somar_bold"
                android:padding="@dimen/_8sdp"
                android:text="English"
                android:gravity="center"
                android:textColor="@color/grey_bold"
                android:textSize="@dimen/_22ssp"
                app:drawableStartCompat="@drawable/icon_en" />


        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/save"
            style="@style/bottom"
            android:layout_marginTop="@dimen/_16sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linear_layout_en" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>