<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <ScrollView
        android:fillViewport="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <ImageView
                android:id="@+id/iv_logo_company"
                android:layout_width="@dimen/_120sdp"
                android:layout_height="@dimen/_120sdp"
                android:src="@drawable/logo_splash"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="@dimen/_16sdp"/>


            <TextView
                android:id="@+id/tv_name_company"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="شركة تسويق"
                android:fontFamily="@font/somar_bold"
                android:textSize="@dimen/_18ssp"
                android:textColor="@color/secondary"
                android:layout_margin="@dimen/_16sdp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_logo_company" />


            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_16sdp"
                android:background="@drawable/shape_bottom2"
                android:fontFamily="@font/somar_bold"
                android:paddingHorizontal="@dimen/_16sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:text="التسويق"
                android:textAlignment="center"
                android:textColor="@color/secondary"
                android:textSize="@dimen/_13ssp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_name_company"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tv_name_company" />


            <TextView
                android:id="@+id/tv_description_cat"
                android:layout_width="0dp"
                android:textAlignment="viewStart"
                android:layout_height="wrap_content"
                android:fontFamily="@font/somar_semi_bold"
                android:text="شركة تسويق"
                android:layout_marginTop="@dimen/_8sdp"
                android:layout_marginHorizontal="@dimen/_16sdp"
                android:textColor="@color/secondary"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_name_company" />


            <TextView
                android:id="@+id/tv_no_order"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_16sdp"
                android:fontFamily="@font/somar_regular"
                android:text="شركة تسويق"
                android:layout_marginTop="@dimen/_8sdp"
                android:textAlignment="viewStart"
                android:textColor="@color/secondary"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_description_cat" />


            <TextView
                android:id="@+id/tv_order_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_16sdp"
                android:fontFamily="@font/somar_regular"
                android:text="شركة تسويق"
                android:inputType="textMultiLine"
                android:lines="5"
                android:background="@drawable/shape_text"
                android:padding="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:textAlignment="viewStart"
                android:textColor="@color/secondary"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_no_order" />




        </androidx.constraintlayout.widget.ConstraintLayout>


    </ScrollView>
</layout>